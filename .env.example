GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GMAIL_ADDRESS=youraddress@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
RECIPIENT_EMAIL=youraddress@gmail.com

# Optional tuning (defaults shown) - free tier Groq models
TRIAGE_MODEL=llama-3.1-8b-instant
GENERATE_MODEL=llama-3.3-70b-versatile
TRIAGE_RELEVANCE_THRESHOLD=6
MAX_STORIES_ANALYZED=10
MAX_SHORT_THREADS=5
MAX_LONGFORM_STORIES=2
LOOKBACK_HOURS=8
