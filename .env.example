GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GMAIL_ADDRESS=youraddress@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
RECIPIENT_EMAIL=youraddress@gmail.com

# Optional tuning (defaults shown) - free tier Groq models
TRIAGE_MODEL=llama-3.1-8b-instant
GENERATE_MODEL=llama-3.3-70b-versatile

# Triage: a headline must score >= this on relevance OR impact (0-10 scale) to survive
TRIAGE_RELEVANCE_THRESHOLD=6
# Max stories triage keeps as candidates for generation, after scoring/ranking
MAX_STORIES_ANALYZED=10
# How many short threads to generate per run (one per top story, in "Today's Threads")
MAX_SHORT_THREADS=5
# How many deep-dive threads to generate per run (overlaps with the top short threads by design)
MAX_LONGFORM_STORIES=2
# How far back (hours) to pull headlines from each RSS feed
LOOKBACK_HOURS=8
# If a draft's self-reported expected_engagement (0-10) is below this, retry once with a
# critique asking for a sharper hook; keeps whichever draft scores higher. Set to 0 to disable.
REGEN_THRESHOLD=6
